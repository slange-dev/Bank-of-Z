//********************************************************************
//*               BIND - BIND THE DB2 PACKAGE                        *
//********************************************************************
//{{parameters['db2_system']['package_jobcard'].strip()}}
//JOBLIB   DD  DISP=SHR,
//             DSN={{parameters['db2_system']['sdsnload']}}
//PKGBIND EXEC PGM=IKJEFT01,DYNAMNBR=20,COND=(4,LT)
//SYSTSPRT DD  SYSOUT=*
//SYSPRINT DD  SYSOUT=*
//SYSUDUMP DD  SYSOUT=*
//SYSIN    DD  DUMMY
//SYSTSIN  DD  *
DSN SYSTEM ({{parameters['db2_system']['subsys']}})
{% for artifact in wd_artifacts %}
BIND  PACKAGE({{parameters['db2_system']['package']}}) +
   MEMBER({{ artifact['name'] }}) +
   LIBRARY('{{item_type['pds']['name']|upper}}') +
   QUALIFIER({{parameters['db2_system']['qualifier']}}) +
   OWNER({{parameters['db2_system']['sqlid']}}) +
   ACTION({{parameters['db2_system']['package_action']}}) +
   ISOLATION(CS) +
   RELEASE(COMMIT) +
{% endfor %}
END
