####################################
# Dataset references
# Global variables for Partition Data Sets (PDS) used by zBuilder Language tasks.
# Please provide a fully qualified DSN for each build variable below.
####################################  
version: 1.0.0
variables:
  # IDZ java library
  - name: IGZXJNI2
    value: {{ dbb.igzxjni2 }}

  # Java home
  - name: JAVA_HOME
    value: {{ java.java_home }}

  # Sandbox directory
  - name: SANDBOX_DIR
    value: {{ sandbox.path }}

  # Gradle home
  - name: GRADLE_HOME
    value: {{ dbb.gradle_home }}

  # z/OS connect http port
  - name: ZOSCONNECT_HTTP_PORT
    value: {{ zosconnect.http_port }}

  # z/OS macro library. Example: SYS1.MACLIB
  - name: MACLIB
    value: SYS1.MACLIB

  # LE (Language Environment) load library. Example: CEE.SCEELKED
  - name: SCEESAMP
    value: CEE.SCEESAMP
    
  # Assembler macro library. Example: CEE.SCEEMAC
  - name: SCEEMAC
    value: CEE.SCEEMAC

  # LE (Language Environment) load library. Example: CEE.SCEELKED
  - name: SCEELKED
    value: CEE.SCEELKED

  # High Level Assembler (HLASM) load library. Example: ASM.SASMMOD1
  - name: SASMMOD1
    value: ASM.SASMMOD1

  # Cobol Compiler Data Sets. Example: COBOL.V4R1M0.SIGYCOMP
  - name: SIGYCOMP
    value: {{ dbb.igy_hlq }}.SIGYCOMP

  # PL/I Compiler Data Sets.  Example: PLI.V5R2M0.SIBMZCMP
  - name: IBMZPLI
    value: "{{ dbb.pli_hlq }}.SIBMZCMP"

  # CICS Macro Library. Example: CICSTS.V3R2M0.CICS.SDFHMAC
  - name: SDFHMAC
    value: "{{ cics.cics_hlq }}.CICS.SDFHMAC"

  # CICS Load Library. Example: CICSTS.V3R2M0.CICS.SDFHLOAD
  - name: SDFHLOAD
    value: "{{ cics.cics_hlq }}.CICS.SDFHLOAD"

  # CICS COBOL Library. Example: CICSTS.V3R2M0.CICS.SDFHCOB
  - name: SDFHCOB
    value: "{{ cics.cics_hlq }}.CICS.SDFHCOB"

  # CICS PLI Library. Example: CICSTS.V3R2M0.CICS.SDFHPL1
  - name: SDFHPL1
    value: DFH.V6R2M24P.CICS.SDFHPL1

  # MQ COBOL Library. Example: CSQ.V9R1M0.SCSQCOBC
  - name: SCSQCOBC
    value: CSQ.V9R1M0.SCSQCOBC

  # MQ PLI Library. Example: CSQ.V9R1M0.SCSQPLIC
  - name: SCSQPLIC
    value: CSQ.V9R3M0.SCSQPLIC 

  # MQ Assembler Library. Example: CSQ.V9R1M0.SCSQMACS
  - name: SCSQMACS
    value: CSQ.V9R3M0.SCSQMACS

  # MQ Load Library. Example: CSQ.V9R1M0.SCSQLOAD
  - name: SCSQLOAD
    value: CSQ.V9R1M0.SCSQLOAD

  # DB2 Load Library. Example: DB2.V9R1M0.SDSNLOAD
  - name: SDSNLOAD
    value: "{{ db2.db2_hlq }}.SDSNLOAD"

  # DB2 Exit Library. Example: DBC0CFG.SDSNEXIT
  - name: SDSNEXIT
    value: "{{ db2.db2_hlq }}.SDSNEXIT"

  # IMS Macro Library. Example: DFS.V11R1M0.SDFSMAC
  - name: SDFSMAC
    value: "{{ ims.ims_sys_hlq }}.SDFSMAC"

  # IMS RESLIB. Example: DFS.V11R1M0.SDFSRESL
  - name: RESLIB
    value: "{{ ims.ims_sys_hlq }}.SDFSRESL"

  # User generated library for DB/DC and DC installations. Example: DFS.V11R1M0.REFERAL
  - name: REFERAL
    value: DFS.V11R1M0.REFERAL

  # IBM Debug Library containing Exits
  #- name: SEQAMOD
  #  value:

  # Optional IDz Load Library. Example: FEL.V14R0M0.SFELLOAD
  - name: SFELLOAD
    value: "{{ dbb.fel_hlq }}.SFELLOAD"

  # REXX Compiler Data Sets. Example: REXX.V1R4.SFANLMD
  #- name: SFANLMD
  #  value:

  - name: MODGEN
    value: SYS1.MODGEN

  # 
  - name: CSSLIB
    value: SYS1.CSSLIB

  # Optional Debug library containing necessary copybooks. 
  - name: SEQASAMP
    value: EQAW.SEQASAMP

  # IBM ADFz Common Components
  - name: SIPVMODA
    value: "{{ dbb.ipv_hlq }}.SIPVMODA"

