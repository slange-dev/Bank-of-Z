  GRANT BINDADD TO MYUSER;

  GRANT CREATEIN ON SCHEMA BANKZ TO MYUSER;

  GRANT CREATE IN COLLECTION BANKZPACK TO MYUSER;
  GRANT PACKADM ON COLLECTION BANKZPACK TO MYUSER;

