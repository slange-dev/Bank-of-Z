//GRANTZ   JOB CLASS=A,MSGCLASS=A,NOTIFY=&SYSUID
//GRANT    EXEC PGM=IKJEFT01,DYNAMNBR=20
//STEPLIB  DD DISP=SHR,DSN=DB2V13.SDSNLOAD
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSUDUMP DD SYSOUT=*
//SYSTSIN  DD *
  DSN SYSTEM(DBD1)
  RUN PROGRAM(DSNTEP2) PLAN(DSNTEP13) -
      LIB('DBD1.RUNLIB.LOAD') PARMS('/ALIGN(MID)')
  END
