<?xml version="1.0" encoding="UTF-8"?>
<server description="CICS configuration">
  <featureManager>
    <feature>zosconnect:cics-1.0</feature>
  </featureManager>

  <zosconnect_cicsIpicConnection id="bankzCicsConnection" host="${CICS_HOST}" port="${CICS_PORT}"
    authDataRef="cicsCredentials" />

  <zosconnect_authData id="cicsCredentials" user="${CICS_USER}" password="${CICS_PASSWORD}" />
</server>