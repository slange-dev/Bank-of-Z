{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Pipeline Simulation",
            "type": "shell",
            "command": "bash",
            "args": [
                "./pipeline-local.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}/.setup"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "detail": "Run Bank of Z pipeline build via Zowe CLI (runs pipeline-common.sh remotely)"
        }
    ]
}
