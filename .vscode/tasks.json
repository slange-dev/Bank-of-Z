{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "releaseVersion",
            "type": "promptString",
            "description": "Release Version",
            "default": "1.0.0"
        },
        {
            "id": "buildNumber",
            "type": "promptString",
            "description": "Build Number",
            "default": "1"
        }
    ],
    "tasks": [
        {
            "label": "Run Pipeline Simulation",
            "type": "shell",
            "command": "./pipeline-local.sh",
            "args": [
                "${input:releaseVersion}",
                "${input:buildNumber}"
            ],
            "options": {
                "cwd": "${workspaceFolder}/.setup"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "detail": "Run Bank of Z pipeline build via Zowe CLI (runs pipeline-common.sh remotely)"
        }
    ]
}
